{
  "name": "speclock-cli",
  "version": "1.0.0",
  "description": "Lock the spec, gate the merge. Spec-driven development for the agentic era. (The CLI command is `speclock`.)",
  "type": "module",
  "bin": {
    "speclock": "dist/cli/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsx src/cli/index.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "check:self": "npm run build && node dist/cli/index.js check",
    "status:self": "npm run build && node dist/cli/index.js status",
    "prepare": "npm run build",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "spec",
    "spec-driven",
    "acceptance-criteria",
    "tdd",
    "testing",
    "ci",
    "cli",
    "agents",
    "ai",
    "vitest",
    "jest",
    "pytest"
  ],
  "author": "speclock contributors",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aymandakir-gh/speclock.git"
  },
  "bugs": {
    "url": "https://github.com/aymandakir-gh/speclock/issues"
  },
  "homepage": "https://github.com/aymandakir-gh/speclock#readme",
  "dependencies": {
    "commander": "^12.1.0",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^20.19.43",
    "@vitest/coverage-v8": "^2.1.9",
    "eslint": "^9.39.4",
    "jest": "^30.4.2",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.61.1",
    "vitest": "^2.1.9"
  }
}
